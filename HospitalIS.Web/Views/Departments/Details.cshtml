@model HospitalIS.Web.Models.Department
@{
    ViewData["Title"] = "Карточка отделения";
}

<h1 class="page-title">Карточка отделения</h1>

<div class="card p-4">
    <dl class="row mb-0">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.HeadFullName)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.HeadFullName)</dd>
    </dl>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редактировать</a>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</div>

