@model HospitalIS.Web.Models.Doctor
@{
    ViewData["Title"] = "Карточка врача";
}

<h1 class="page-title mb-3">Карточка врача</h1>

<div class="surface p-4 mb-3">
    <dl class="row mb-0">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FullName)</dt>
        <dd class="col-sm-9">@Model.FullName</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Specialty)</dt>
        <dd class="col-sm-9">@Model.Specialty</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.OfficeNumber)</dt>
        <dd class="col-sm-9">@Model.OfficeNumber</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Phone)</dt>
        <dd class="col-sm-9">@Model.Phone</dd>

        <dt class="col-sm-3">Количество приемов</dt>
        <dd class="col-sm-9">@Model.Appointments.Count</dd>
    </dl>
</div>

<div class="surface p-3 mb-3">
    <h2 class="section-title mb-3">Ближайшие приемы врача</h2>

    @if (!Model.Appointments.Any())
    {
        <div class="empty-state">Записи на прием отсутствуют.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-app align-middle mb-0">
                <thead>
                    <tr>
                        <th>Дата и время</th>
                        <th>Пациент</th>
                        <th>Диагноз</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var appointment in Model.Appointments)
                {
                    <tr>
                        <td>@appointment.AppointmentDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@appointment.Patient?.FullName</td>
                        <td>@appointment.Diagnosis</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редактировать</a>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</div>

