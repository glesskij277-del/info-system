@model HospitalIS.Web.Models.MedicalRecord
@{
    ViewData["Title"] = "Карточка медкарты";
}

<h1 class="page-title mb-3">Карточка медкарты</h1>

<div class="surface p-4">
    <dl class="row mb-0">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CardNumber)</dt>
        <dd class="col-sm-9">@Model.CardNumber</dd>

        <dt class="col-sm-3">Пациент</dt>
        <dd class="col-sm-9">@Model.Patient?.FullName</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedDate)</dt>
        <dd class="col-sm-9">@Model.CreatedDate.ToString("dd.MM.yyyy")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DiseaseHistory)</dt>
        <dd class="col-sm-9" style="white-space: pre-line;">@Model.DiseaseHistory</dd>
    </dl>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редактировать</a>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</div>

