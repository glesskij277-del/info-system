@model HospitalIS.Web.Models.Patient
@{
    ViewData["Title"] = "Удаление пациента";
}

<h1 class="page-title text-danger">Удаление пациента</h1>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="card p-4">
    <p>Вы уверены, что хотите удалить пациента?</p>
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FullName)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.FullName)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.OmsPolicyNumber)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.OmsPolicyNumber)</dd>
    </dl>

    <div class="mb-3">
        <p class="mb-1"><strong>Связанные приемы:</strong> @ViewData["AppointmentsCount"]</p>
        <p class="mb-0"><strong>Медкарта заведена:</strong> @((ViewData["HasMedicalRecord"] is bool has && has) ? "Да" : "Нет")</p>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
    </form>
</div>

