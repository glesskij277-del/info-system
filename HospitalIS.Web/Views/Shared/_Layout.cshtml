@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string NavClass(string controllerName) =>
        string.Equals(currentController, controllerName, StringComparison.OrdinalIgnoreCase)
            ? "nav-link nav-link-active"
            : "nav-link";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hospital Patient Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    <div class="bg-orb orb-one"></div>
    <div class="bg-orb orb-two"></div>

    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">HospitalIS · Patient Management</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Переключить навигацию">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">Главная</a></li>
                        <li class="nav-item"><a class="@NavClass("Patients")" asp-controller="Patients" asp-action="Index">Пациенты</a></li>
                        <li class="nav-item"><a class="@NavClass("Doctors")" asp-controller="Doctors" asp-action="Index">Врачи</a></li>
                        <li class="nav-item"><a class="@NavClass("Appointments")" asp-controller="Appointments" asp-action="Index">Приемы</a></li>
                        <li class="nav-item"><a class="@NavClass("MedicalRecords")" asp-controller="MedicalRecords" asp-action="Index">Медкарты</a></li>
                        <li class="nav-item"><a class="@NavClass("Departments")" asp-controller="Departments" asp-action="Index">Отделения</a></li>
                        <li class="nav-item"><a class="@NavClass("Reports")" asp-controller="Reports" asp-action="Index">Отчеты</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4 app-main">
        <partial name="_FlashMessages" />
        @RenderBody()
    </main>

    <footer class="app-footer">
        <div class="container">
            <p class="mb-0">HospitalIS · Patient Management System</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

